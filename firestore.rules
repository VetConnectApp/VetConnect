rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getDocRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && (
        ('role' in request.auth.token && request.auth.token.role == 'admin') ||
        getDocRole() == 'admin'
      );
    }
    
    function isVet() {
      return request.auth != null && (
        ('role' in request.auth.token && request.auth.token.role == 'vet') ||
        getDocRole() == 'vet'
      );
    }
    
    function isFarmer() {
      return request.auth != null && (
        ('role' in request.auth.token && request.auth.token.role == 'farmer') ||
        getDocRole() == 'farmer'
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    match /animals/{animalId} {
      allow create, update: if isVet() || isAdmin();
      allow read: if isVet() || isAdmin() || (isFarmer() && resource.data.farmerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /treatments/{treatmentId} {
      allow create: if isVet() || isAdmin();
      allow update: if isAdmin() || (isVet() && resource.data.vetId == request.auth.uid);
      allow read: if isVet() || isAdmin() || (isFarmer() && resource.data.farmerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /emergencies/{emergencyId} {
      allow create: if isFarmer() && request.resource.data.farmerId == request.auth.uid;
      allow read, update: if isVet() || isAdmin() || (isFarmer() && resource.data.farmerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /update_requests/{requestId} {
      allow create: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}